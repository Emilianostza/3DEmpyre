# ============================================================================
# 3D Empyre — Frontend Environment Variables (Vite)
# ============================================================================
#
# This file is for REFERENCE ONLY — do NOT create .env.local for production.
#
# Architecture:
#   Frontend (Vite SPA)  →  Cloudflare Workers (API / Auth)  →  Supabase
#
# Secrets (SUPABASE_SERVICE_ROLE_KEY, GEMINI_API_KEY) are stored as
# Cloudflare Worker secrets via `wrangler secret put`. See .dev.vars.example
# for local Worker development.
#
# Local Development:
#   The app defaults to VITE_USE_MOCK_DATA=true — no API keys needed locally.
#   Mock data simulates backend responses with artificial delays.
# ============================================================================

# ── Feature Flags ────────────────────────────────────────────────────────────
# Set to "false" to connect to real Supabase backend
VITE_USE_MOCK_DATA=true

# ── API ──────────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3001/api

# ── Supabase (required when VITE_USE_MOCK_DATA=false) ────────────────────────
# Get from: https://app.supabase.com/project/[PROJECT_ID]/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Storage ──────────────────────────────────────────────────────────────────
VITE_STORAGE_PROVIDER=supabase
VITE_STORAGE_BUCKET=https://s3.example.com/3d-empyre
